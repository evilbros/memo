{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "SenseNova": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SenseNova",
      "options": {
        "baseURL": "https://token.sensenova.cn/v1",
        "apiKey": ""
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash",
          "limit": {
            "context": 256000,
            "output": 65536
          }
        }
      }
    }
  }
}

